# Локальная разработка — SQLite, без Docker.
# Скопировать в .env и заполнить секреты перед первым запуском.

KEY=change-me-random-uuid
SECRET=change-me-random-uuid

DB_CLIENT=sqlite3
DB_FILENAME=./database/data.db

CACHE_ENABLED=false

ADMIN_EMAIL=admin@kamsnab.ru
ADMIN_PASSWORD=change-me

PUBLIC_URL=http://localhost:8055

# Локальные фронты обращаются к Directus с других origin (3000/5173/5174) —
# нужен явный CORS. В проде фронты и Directus разносятся по поддоменам, там
# CORS_ORIGIN нужно указать точными адресами (не true).
CORS_ENABLED=true
CORS_ORIGIN=true

# --- Уведомления о заявках (Directus Flows -> вебхуки ботов) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
MAX_BOT_TOKEN=
MAX_MANAGER_CHAT_ID=

# --- Почта: письмо на kam-snab@mail.ru при новой заявке ---
# Flow уже настроен (schema/seed.mjs), но без EMAIL_TRANSPORT=smtp письма не
# уходят — Directus по умолчанию пытается использовать sendmail, которого
# нет. Пример для smtp.mail.ru (нужен пароль для внешних приложений, обычный
# пароль ящика может не подойти):
# EMAIL_TRANSPORT=smtp
# EMAIL_SMTP_HOST=smtp.mail.ru
# EMAIL_SMTP_PORT=465
# EMAIL_SMTP_SECURE=true
# EMAIL_SMTP_USER=
# EMAIL_SMTP_PASSWORD=
# EMAIL_FROM=
