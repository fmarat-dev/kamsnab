POSTGRES_PASSWORD=change-me
DIRECTUS_KEY=change-me-random-uuid
DIRECTUS_SECRET=change-me-random-uuid
ADMIN_EMAIL=admin@kamsnab.ru
ADMIN_PASSWORD=change-me
DIRECTUS_PUBLIC_URL=https://cms.kamsnab.ru

# Список origin через запятую, без wildcard — сайт + оба mini app
CORS_ORIGIN=https://kamsnab.ru,https://tg.kamsnab.ru,https://max.kamsnab.ru

TELEGRAM_BOT_TOKEN=
TELEGRAM_MANAGER_CHAT_ID=
MAX_BOT_TOKEN=
MAX_MANAGER_CHAT_ID=

# --- Почта: письмо на kam-snab@mail.ru при новой заявке (Directus Flow) ---
# Пример для smtp.mail.ru (нужен пароль для внешних приложений):
EMAIL_TRANSPORT=smtp
EMAIL_SMTP_HOST=smtp.mail.ru
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM=

# --- Сборка фронтов (сайт + мини-аппы) ---
# Значения "вшиваются" в статику на этапе docker build (Next.js NEXT_PUBLIC_*
# и Vite VITE_* — build-time переменные), поэтому при их изменении нужен
# пересобранный образ: docker compose up -d --build.
NEXT_PUBLIC_DIRECTUS_URL=https://cms.kamsnab.ru
NEXT_PUBLIC_SITE_URL=https://kamsnab.ru
VITE_DIRECTUS_URL=https://cms.kamsnab.ru
VITE_MANAGER_TELEGRAM_USERNAME=kamsnab_manager
VITE_MANAGER_MAX_LINK=https://max.ru/kamsnab_manager
